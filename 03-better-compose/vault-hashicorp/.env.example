# Vault dev (jouet pédagogique) — copier en .env :  cp .env.example .env
# /!\ Valeurs de DEV uniquement (token fixe "root", Vault déverrouillé en mémoire).
#     JAMAIS en prod. Le .env est gitignoré ; seul ce .env.example est commité.

# Adresse du serveur Vault (CLI côté hôte) + token root du mode dev.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# Doit correspondre au VAULT_DEV_ROOT_TOKEN_ID du compose.yaml (mode dev).
VAULT_DEV_ROOT_TOKEN_ID=root
